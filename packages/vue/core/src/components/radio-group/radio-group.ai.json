  "generationHints": {
    "preferredUsageOrder": [
      "modelValue / defaultValue",
      "orientation",
      "theme.size",
      "RadioGroupItem.value",
      "RadioGroupItem.variant"
    ],
    "safeDefaults": {
      "orientation": "horizontal",
      "RadioGroupItem.variant": "default"
    },
    "a11yChecklist": [
      "同一组选项保持 value 类型一致",
      "组级 label 插槽或 aria-label 提供可访问性说明",
      "disabled 状态需提供可感知视觉反馈"
    ],
    "codegenTemplates": {
      "minimal": "<RadioGroup v-model=\"value\">\n  <RadioGroupItem value=\"a\" label=\"A\" />\n  <RadioGroupItem value=\"b\" label=\"B\" />\n</RadioGroup>",
      "controlled": "<RadioGroup v-model=\"selected\" orientation=\"vertical\">\n  <RadioGroupItem value=\"1\" label=\"选项 1\" />\n  <RadioGroupItem value=\"2\" label=\"选项 2\" />\n</RadioGroup>"
    },
    "antiPatterns": [
      "同一组内 value 类型混用（字符串与数字混用）",
      "未使用 label 或默认插槽导致选项无文本",
      "样式定制直接改内部结构而非 theme/ui"
    ]
  },
  "provenance": {
    "sources": [
      { "path": "./radio-group.doc.mdx", "kind": "doc" },
      { "path": "./props.ts", "kind": "type" },
      { "path": "./RadioGroup.vue", "kind": "runtime" },
      { "path": "./RadioGroupItem.vue", "kind": "runtime" },
      { "path": "./radio-group.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.props.orientation.default": "doc",
      "RadioGroupItem.variant.default": "runtime",
      "contracts.themeConfiguration.fields.size.default": "doc"
    }
  }
}
