{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.radio-group",
  "component": {
    "name": "RadioGroup",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "RadioGroup",
    "category": "core",
    "description": "用于管理单选集合场景，适合筛选条件、配置项切换、设置面板等只允许选择一个值的交互。基于 Ark UI Radio Group 原语构建，支持受控/非受控值管理，并扩展 theme、variant 以及 ui 样式入口。需配合 RadioGroupItem 使用。",
    "basePrimitive": {
      "library": "@ark-ui/vue/radio-group",
      "primitive": "RadioGroup.RootProvider",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": [
        "aria-*",
        "data-*"
      ],
      "notes": "组件基于 Ark UI Radio Group 封装，通过 useRadioGroup 承接组值状态。"
    },
    "capabilities": [
      "v-model",
      "theme",
      "ui-override",
      "orientation",
      "composite-item"
    ]
  },
  "contracts": {
    "props": [
      {
        "name": "modelValue",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | number | symbol | bigint | null",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "symbol" },
            { "type": "bigint" },
            { "type": "null" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "受控模式下的当前值（配合 v-model）"
      },
      {
        "name": "defaultValue",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | number | symbol | bigint | null",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "symbol" },
            { "type": "bigint" },
            { "type": "null" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "非受控模式下的初始值"
      },
      {
        "name": "orientation",
        "required": false,
        "requiredSource": "doc",
        "typeText": "'horizontal' | 'vertical'",
        "typeSchema": {
          "enum": ["horizontal", "vertical"]
        },
        "default": "horizontal",
        "defaultKind": "explicit-doc",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "布局方向"
      },
      {
        "name": "disabled",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "禁用整组交互"
      },
      {
        "name": "name",
        "required": false,
        "requiredSource": "type",
        "typeText": "string",
        "typeSchema": { "type": "string" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "组内隐藏输入的字段名（表单提交语义）"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | array | object",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "array" },
            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点附加 class"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvRadioGroup'>",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "主题参数与 crafts 覆盖入口"
      }
    ],
    "events": [
      {
        "name": "update:modelValue",
        "payload": {
          "typeText": "(value: string | number | symbol | bigint | null)",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "null" }
            ]
          }
        },
        "emitWhen": [
          { "expr": "value_changed", "kind": "runtime-hook" }
        ],
        "notEmitWhen": [],
        "order": ["emit:update:modelValue"],
        "description": "组值变化时触发，用于 v-model 同步"
      },
      {
        "name": "valueChange",
        "payload": {
          "typeText": "(details: { value: string | number | symbol | bigint | null })",
          "typeSchema": {
            "type": "object",
            "properties": {
              "value": {
                "anyOf": [
                  { "type": "string" },
                  { "type": "number" },
                  { "type": "null" }
                ]
              }
            }
          }
        },
        "emitWhen": [
          { "expr": "radio_checked", "kind": "runtime-hook" }
        ],
        "notEmitWhen": [],
        "order": ["emit:valueChange"],
        "description": "单选值变化详情事件"
      }
    ],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "组内容器插槽，通常放置多个 RadioGroupItem"
      },
      {
        "name": "label",
        "slotPropsSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "组级标题/说明区域插槽（渲染在 items 之前）"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": {
            "enum": ["xs", "sm", "base", "lg"]
          },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "控制 control/indicator/text 的尺寸体系"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "深度覆写 root/item/itemControl/itemIndicator/itemText 样式"
        }
      ]
    },
    "uiConfiguration": {
      "fields": [
        {
          "name": "RadioGroupItem.ui.root.class",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "单选项根节点 class 覆盖"
        },
        {
          "name": "RadioGroupItem.ui.control.class",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "控制区 class 覆盖"
        },
        {
          "name": "RadioGroupItem.ui.indicator.class",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "指示器 class 覆盖"
        },
        {
          "name": "RadioGroupItem.ui.text.class",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "文本节点 class 覆盖"
        }
      ]
    }
  },
  "behaviorModel": {
    "stateVars": {
      "modelValue": "string | number | symbol | bigint | null",
      "disabled": "boolean | undefined",
      "orientation": "'horizontal' | 'vertical'"
    },
    "derived": {
      "checkedItem": "RadioGroupItem with value === modelValue"
    },
    "transitions": [
      {
        "on": "item_select",
        "guard": "disabled !== true",
        "effects": [
          "set modelValue = item.value",
          "emit(update:modelValue, value)",
          "emit(valueChange, { value })"
        ]
      }
    ]
  },
