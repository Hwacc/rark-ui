  "generationHints": {
    "preferredUsageOrder": [
      "modelValue / defaultValue",
      "count",
      "allowHalf",
      "theme.size",
      "disabled / readOnly"
    ],
    "safeDefaults": {
      "count": 5,
      "allowHalf": false,
      "disabled": false,
      "readOnly": false
    },
    "a11yChecklist": [
      "评分组件需提供 aria-label 或 aria-labelledby 说明用途",
      "readOnly 与 disabled 语义不同，需区分使用",
      "半星评分需考虑屏幕阅读器对部分值的表达"
    ],
    "codegenTemplates": {
      "minimal": "<RatingGroup v-model=\"rating\" />",
      "controlled": "<RatingGroup v-model=\"rating\" :count=\"5\" :allow-half=\"true\" />"
    },
    "antiPatterns": [
      "只读展示与禁用交互语义混用",
      "未监听 valueChange 与 hoverChange 导致无法区分预览与提交",
      "样式定制直接改内部结构而非 theme/ui"
    ]
  },
