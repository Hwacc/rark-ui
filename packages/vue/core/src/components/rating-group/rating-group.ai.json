      {
        "name": "readOnly",
        "required": false,
        "requiredSource": "doc",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": false,
        "defaultKind": "explicit-doc",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
