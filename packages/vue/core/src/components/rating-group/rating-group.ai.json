{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.rating-group",
  "component": {
    "name": "RatingGroup",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "RatingGroup",
    "category": "core",
    "description": "用于评分场景（如满意度、服务质量、内容打分），支持受控/非受控值管理、悬浮预览、半星评分和禁用/只读状态。基于 Ark UI Rating Group 构建，扩展 theme 与 ui 样式入口，暴露 $api 便于编程式设置与清空评分。",
    "basePrimitive": {
      "library": "@ark-ui/vue/rating-group",
      "primitive": "RatingGroup.RootProvider",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": ["aria-*", "data-*"],
      "notes": "组件基于 Ark UI Rating Group 原语封装，透传 Root 常用能力。"
    },
    "capabilities": [
      "v-model",
      "theme",
      "ui-override",
      "allow-half",
      "programmatic-api"
    ]
  },
  "contracts": {
