        "dependsOn": [],
        "conflictsWith": [],
        "description": "非受控初始评分值"
      },
      {
        "name": "count",
        "required": false,
        "requiredSource": "doc",
        "typeText": "number",
        "typeSchema": { "type": "number" },
        "default": 5,
        "defaultKind": "explicit-doc",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "评分项数量"
      },
      {
