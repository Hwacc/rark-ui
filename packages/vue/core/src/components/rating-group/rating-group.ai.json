            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点 class"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvRatingGroup'>",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "主题参数与 crafts 覆盖"
      },
      {
        "name": "ui",
        "required": false,
        "requiredSource": "type",
        "typeText": "{ root?: { class?: string | array | object }, control?: { class?: string | array | object } }",
        "typeSchema": {
          "type": "object",
          "properties": {
            "root": {
              "type": "object",
              "properties": {
                "class": {
                  "anyOf": [
                    { "type": "string" },
                    { "type": "array" },
                    { "type": "object" }
                  ]
                }
              },
              "additionalProperties": true
            },
            "control": {
              "type": "object",
              "properties": {
                "class": {
                  "anyOf": [
                    { "type": "string" },
                    { "type": "array" },
                    { "type": "object" }
                  ]
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "局部样式覆盖配置"
      }
    ],
    "events": [
      {
        "name": "update:modelValue",
        "payload": {
          "typeText": "(value: number)",
          "typeSchema": { "type": "number" }
        },
        "emitWhen": [
          { "expr": "value_changed", "kind": "runtime-hook" }
        ],
        "notEmitWhen": [],
        "order": ["emit:update:modelValue"],
        "description": "受控值同步事件（对应 v-model）"
      },
      {
        "name": "valueChange",
        "payload": {
          "typeText": "(details: { value: number })",
          "typeSchema": {
            "type": "object",
            "properties": { "value": { "type": "number" } }
          }
        },
        "emitWhen": [
          { "expr": "rating_selected", "kind": "runtime-hook" }
        ],
        "notEmitWhen": [],
        "order": ["emit:valueChange"],
        "description": "评分值变化时触发"
      },
      {
        "name": "hoverChange",
        "payload": {
          "typeText": "(details: { hoveredValue: number })",
          "typeSchema": {
            "type": "object",
            "properties": { "hoveredValue": { "type": "number" } }
          }
        },
        "emitWhen": [
          { "expr": "hover_value_changed", "kind": "runtime-hook" }
        ],
        "notEmitWhen": [],
        "order": ["emit:hoverChange"],
        "description": "悬浮评分变化时触发"
      }
    ],
    "slots": [
      {
        "name": "prefix",
        "slotPropsSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "评分区域前置内容"
      },
      {
        "name": "default",
        "slotPropsSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": true
        },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "评分项渲染插槽，作用域参数包含 items"
      },
      {
        "name": "suffix",
        "slotPropsSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "评分区域后置内容"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": {
            "enum": ["xs", "sm", "base", "lg"]
          },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "评分图标尺寸与间距节奏"
        },
        {
          "name": "skin",
          "typeText": "'razer' | 'shadcn'",
          "typeSchema": {
            "enum": ["razer", "shadcn"]
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "主题皮肤"
        },
        {
          "name": "surface",
          "typeText": "'light' | 'dark'",
          "typeSchema": {
            "enum": ["light", "dark"]
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "亮/暗表面语义"
        },
        {
          "name": "unstyled",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": null,
          "defaultKind": "unknown",
          "description": "移除默认样式"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆盖 tvRatingGroup 的 crafts 配置"
        }
      ]
    },
    "uiConfiguration": {
      "fields": [
        {
          "name": "ui.root.class",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "根节点 class"
        },
        {
          "name": "ui.control.class",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "评分控制容器 class"
        }
      ]
    }
  },
  "behaviorModel": {
    "stateVars": {
      "modelValue": "number",
      "disabled": "boolean",
      "readOnly": "boolean",
      "allowHalf": "boolean",
      "count": "number"
    },
    "derived": {
      "hoveredValue": "当前悬浮评分"
    },
    "transitions": [
      {
        "on": "item_select",
        "guard": "disabled !== true && readOnly !== true",
        "effects": [
          "set modelValue = selectedValue",
          "emit(update:modelValue, value)",
          "emit(valueChange, { value })"
        ]
      },
      {
        "on": "item_hover",
        "guard": "always",
        "effects": ["emit(hoverChange, { hoveredValue })"]
      }
    ]
  },
