{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.pagination",
  "component": {
    "name": "Pagination",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "Pagination",
    "category": "core",
    "description": "用于列表、表格等长数据场景的页码导航，支持上一页/下一页、首尾页、省略页码展示以及受控分页状态管理。基于 Ark UI Pagination 构建，扩展 theme 与 ui 配置。",
    "basePrimitive": {
      "library": "@ark-ui/vue/pagination",
      "primitive": "Pagination.RootProvider",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": [
        "aria-*",
        "data-*"
      ],
      "notes": "透传 Ark UI PaginationRootBaseProps；theme、ui 为 Rark 扩展。"
    },
    "capabilities": [
      "v-model:page",
      "v-model:page-size",
      "theme",
      "ui-override",
      "programmatic-api"
    ]
  },
  "contracts": {
    "props": [
      {
        "name": "page",
        "required": false,
        "requiredSource": "type",
        "typeText": "number",
        "typeSchema": { "type": "number" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "受控当前页（配合 v-model:page）。"
      },
      {
        "name": "pageSize",
        "required": false,
        "requiredSource": "type",
        "typeText": "number",
        "typeSchema": { "type": "number" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "受控每页条数（配合 v-model:page-size）。"
      },
      {
        "name": "count",
        "required": false,
        "requiredSource": "type",
        "typeText": "number",
        "typeSchema": { "type": "number" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "总条目数。"
      },
      {
        "name": "defaultPage",
        "required": false,
        "requiredSource": "type",
        "typeText": "number",
        "typeSchema": { "type": "number" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "非受控模式下的初始页码。"
      },
      {
        "name": "defaultPageSize",
        "required": false,
        "requiredSource": "type",
        "typeText": "number",
        "typeSchema": { "type": "number" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "非受控模式下的初始每页条数。"
      },
      {
        "name": "siblingCount",
        "required": false,
        "requiredSource": "type",
        "typeText": "number",
        "typeSchema": { "type": "number" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "当前页两侧展示的相邻页码数量。"
      },
      {
        "name": "type",
        "required": false,
        "requiredSource": "type",
        "typeText": "'button' | 'link'",
        "typeSchema": { "enum": ["button", "link"] },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "触发元素类型；link 模式下可生成跳转 URL。"
      },
      {
        "name": "getPageUrl",
        "required": false,
        "requiredSource": "type",
        "typeText": "(details: { page: number }) => string",
        "typeSchema": { "type": "function" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": ["type"],
        "conflictsWith": [],
        "description": "type='link' 时用于生成页码链接。"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | array | object",
        "typeSchema": {
          "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点自定义 class。"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvPagination'>",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "分页主题参数与 crafts 覆盖。"
      },
      {
        "name": "ui",
        "required": false,
        "requiredSource": "type",
        "typeText": "{ root?: class; control?: class; firstPage?: class; prevPage?: class; nextPage?: class; lastPage?: class; item?: class; ellipsis?: class }",
        "typeSchema": {
          "type": "object",
          "properties": {
            "root": {},
            "control": {},
            "firstPage": {},
            "prevPage": {},
            "nextPage": {},
            "lastPage": {},
            "item": {},
            "ellipsis": {}
          }
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "各结构节点 class 覆盖。"
      }
    ],
    "events": [
      {
        "name": "update:page",
        "payload": { "typeText": "(page: number)", "typeSchema": { "type": "object", "x-ts-type": "number" } },
        "emitWhen": [{ "expr": "page_changed", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:update:page"],
        "description": "当前页变化时触发，用于 v-model:page。"
      },
      {
        "name": "update:page-size",
        "payload": { "typeText": "(pageSize: number)", "typeSchema": { "type": "object", "x-ts-type": "number" } },
        "emitWhen": [{ "expr": "page_size_changed", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:update:page-size"],
        "description": "每页条数变化时触发，用于 v-model:page-size。"
      },
      {
        "name": "page-change",
        "payload": { "typeText": "(details: { page: number; pageSize: number })", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "page_changed", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": [],
        "description": "页码变化回调。"
      },
      {
        "name": "page-size-change",
        "payload": { "typeText": "(details: { pageSize: number })", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "page_size_changed", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": [],
        "description": "每页条数变化回调。"
      }
    ],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": { "type": "object", "properties": {}, "additionalProperties": false },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "放置附加能力组件（如 PaginationGoTo、PaginationPageSize）。"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'sm' | 'base' | 'lg'",
          "typeSchema": { "enum": ["sm", "base", "lg"] },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "分页尺寸。"
        },
        {
          "name": "skin",
          "typeText": "'razer' | 'shadcn'",
          "typeSchema": { "enum": ["razer", "shadcn"] },
          "default": null,
          "defaultKind": "unknown",
          "description": "主题皮肤。"
        },
        {
          "name": "surface",
          "typeText": "'light' | 'dark'",
          "typeSchema": { "enum": ["light", "dark"] },
          "default": null,
          "defaultKind": "unknown",
          "description": "亮/暗表面语义。"
        },
        {
          "name": "unstyled",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": null,
          "defaultKind": "unknown",
          "description": "移除默认样式。"
        }
      ]
    },
    "uiConfiguration": {
      "fields": [
        { "name": "ui.root", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "分页根容器 class" },
        { "name": "ui.control", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "分页控制区 class" },
        { "name": "ui.firstPage", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "首页按钮 class" },
        { "name": "ui.prevPage", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "上一页按钮 class" },
        { "name": "ui.nextPage", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "下一页按钮 class" },
        { "name": "ui.lastPage", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "末页按钮 class" },
        { "name": "ui.item", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "页码项 class" },
        { "name": "ui.ellipsis", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "省略节点 class" }
      ]
    }
  },
  "behaviorModel": {
    "stateVars": {
      "page": "number",
      "pageSize": "number",
      "pages": "Array<{ type: 'page' | 'ellipsis'; value?: number }>"
    },
    "derived": {
      "totalPages": "Math.ceil(count / pageSize)",
      "canGoPrev": "page > 1",
      "canGoNext": "page < totalPages"
    },
    "transitions": [
      {
        "on": "goToFirstPage",
        "guard": "page > 1",
        "effects": ["page = 1", "emit(update:page)"]
      },
      {
        "on": "goToLastPage",
        "guard": "page < totalPages",
        "effects": ["page = totalPages", "emit(update:page)"]
      },
      {
        "on": "prevPage",
        "guard": "canGoPrev",
        "effects": ["page -= 1", "emit(update:page)"]
      },
      {
        "on": "nextPage",
        "guard": "canGoNext",
        "effects": ["page += 1", "emit(update:page)"]
      }
    ]
  },
  "examples": [
    { "id": "basic", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Pagination" }, "exampleId": "basic" }, "description": "基础用法" },
    { "id": "minimal", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Pagination" }, "exampleId": "minimal" }, "description": "精简模式" },
    { "id": "sizes", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Pagination" }, "exampleId": "sizes" }, "description": "尺寸变体" },
    { "id": "controlled", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Pagination" }, "exampleId": "controlled" }, "description": "受控分页与每页条数" },
    { "id": "events", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Pagination" }, "exampleId": "events" }, "description": "事件监听" },
    { "id": "link-type", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Pagination" }, "exampleId": "link-type" }, "description": "Link 模式" }
  ],
  "generationHints": {
    "preferredUsageOrder": ["count", "page/pageSize", "defaultPage/defaultPageSize", "theme"],
    "safeDefaults": {},
    "a11yChecklist": [
      "type='link' 场景建议始终提供 getPageUrl",
      "分页状态需要与 URL 同步时优先使用受控模式"
    ],
    "codegenTemplates": {
      "minimal": "<Pagination :count=\"100\" />",
      "controlled": "<Pagination v-model:page=\"page\" v-model:page-size=\"pageSize\" :count=\"total\" />"
    },
    "antiPatterns": [
      "type='link' 未提供 getPageUrl 导致无法生成跳转链接",
      "数据量变化后未同步重置 page 导致空页展示"
    ]
  },
  "provenance": {
    "sources": [
      { "path": "./pagination.doc.mdx", "kind": "doc" },
      { "path": "./props.ts", "kind": "type" },
      { "path": "./Pagination.vue", "kind": "runtime" },
      { "path": "./pagination.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.themeConfiguration.fields.size.default": "doc"
    }
  }
