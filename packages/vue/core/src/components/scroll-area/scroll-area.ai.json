{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.scroll-area",
  "component": {
    "name": "ScrollArea",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "ScrollArea",
    "category": "core",
    "description": "用于在固定容器内承载可滚动内容，支持垂直/水平滚动条组合与角落补位（Corner）。基于 Ark UI Scroll Area 构建，透传 Ark UI Root 能力，并扩展 theme 与 ui 配置。",
    "basePrimitive": {
      "library": "@ark-ui/vue/scroll-area",
      "primitive": "ark.scroll-area",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": ["aria-*", "data-*"],
      "notes": "根组件透传 ScrollAreaRootBaseProps 到底层 Ark UI Root。"
    },
    "capabilities": [
      "theme",
      "ui-override",
      "scroll-events",
      "conditional-scrollbar"
    ]
  },
  "contracts": {
    "props": [
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | array | object",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "array" },
            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点自定义 class"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ScrollAreaTheme",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根组件主题配置（含 size 与 crafts 覆盖）"
      },
      {
        "name": "ui",
        "required": false,
        "requiredSource": "type",
        "typeText": "{ root?: HTMLAttributes['class']; viewport?: HTMLAttributes['class']; content?: HTMLAttributes['class'] }",
        "typeSchema": {
          "type": "object",
          "properties": {
            "root": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
            "viewport": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
            "content": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }
          },
          "additionalProperties": true
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "局部样式覆盖（root/viewport/content）"
      }
    ],
    "events": [
      {
        "name": "scrollstart",
        "payload": {
          "typeText": "(event: Event)",
          "typeSchema": { "type": "object", "x-ts-type": "Event" }
        },
        "emitWhen": [{ "expr": "viewport_scroll_start", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:scrollstart"],
        "description": "Viewport 开始滚动时触发"
      },
      {
        "name": "scroll",
        "payload": {
          "typeText": "(event: Event)",
          "typeSchema": { "type": "object", "x-ts-type": "Event" }
        },
        "emitWhen": [{ "expr": "viewport_scrolling", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:scroll"],
        "description": "Viewport 滚动过程中触发"
      },
      {
        "name": "scrollend",
        "payload": {
          "typeText": "(event: Event)",
          "typeSchema": { "type": "object", "x-ts-type": "Event" }
        },
        "emitWhen": [{ "expr": "viewport_scroll_end", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:scrollend"],
        "description": "Viewport 结束滚动时触发"
      }
    ],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": { "type": "object", "properties": {}, "additionalProperties": false },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "内容与子组件插槽；可放置业务内容、ScrollAreaScrollbar、ScrollAreaCorner"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": { "enum": ["xs", "sm", "base", "lg"] },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "滚动条尺寸变体（影响 scrollbar 与 thumb 厚度）"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆盖 tvScrollArea crafts 配置"
        }
      ]
    },
    "uiConfiguration": {
      "fields": [
        { "name": "ui.root", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "根节点 class 覆盖" },
        { "name": "ui.viewport", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "Viewport 节点 class 覆盖" },
        { "name": "ui.content", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "Content 节点 class 覆盖" }
      ]
    }
  },
  "behaviorModel": {
    "stateVars": {},
    "derived": {
      "isShowScrollbarsVertical": "viewportHeight < contentHeight",
      "isShowScrollbarsHorizontal": "viewportWidth < contentWidth"
    },
    "transitions": [
      {
        "on": "scroll",
        "guard": "always",
        "effects": ["emit(scrollstart) on start", "emit(scroll) during", "emit(scrollend) on end"]
      }
    ]
  },
  "examples": [
    { "id": "basic", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "ScrollArea" }, "exampleId": "basic" }, "description": "基础用法" },
    { "id": "both-axes", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "ScrollArea" }, "exampleId": "both-axes" }, "description": "双轴滚动与 Corner" },
    { "id": "sizes", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "ScrollArea" }, "exampleId": "sizes" }, "description": "尺寸变体" },
    { "id": "custom-ui", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "ScrollArea" }, "exampleId": "custom-ui" }, "description": "UI 定制" }
  ],
  "generationHints": {
    "preferredUsageOrder": ["theme.size", "ui.root", "ui.viewport", "ui.content"],
    "safeDefaults": {},
    "a11yChecklist": [
      "推荐按 ScrollArea + ScrollAreaScrollbar (+ ScrollAreaCorner) 的固定结构组合",
      "单轴滚动场景仅保留一个 ScrollAreaScrollbar",
      "双轴场景补充 orientation=\"horizontal\" 与 ScrollAreaCorner"
    ],
    "codegenTemplates": {
      "minimal": "<ScrollArea><ScrollAreaScrollbar /><div>content</div></ScrollArea>",
      "bothAxes": "<ScrollArea><ScrollAreaScrollbar /><ScrollAreaScrollbar orientation=\"horizontal\" /><ScrollAreaCorner /><div>content</div></ScrollArea>"
    },
    "antiPatterns": [
      "遗漏滚动条节点导致可滚动但无反馈",
      "依赖外层页面滚动替代局部滚动区域"
    ]
  },
  "provenance": {
    "sources": [
      { "path": "./scroll-area.doc.mdx", "kind": "doc" },
      { "path": "./props.ts", "kind": "type" },
      { "path": "./ScrollArea.vue", "kind": "runtime" },
      { "path": "./scroll-area.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.themeConfiguration.fields.size.default": "doc",
      "contracts.events.scrollstart": "runtime"
    }
  }
}
