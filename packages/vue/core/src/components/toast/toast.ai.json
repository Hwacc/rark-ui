{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.toast",
  "component": {
    "name": "Toast",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "Toast",
    "category": "core",
    "description": "基于 Ark UI Toast 封装的全局轻提示方案，适合异步反馈、状态提醒与轻量操作提示。由 ToasterManager、Toaster 和 Toast 组合，支持 useToast() 编程式调用、theme 与 ui 配置。",
    "basePrimitive": {
      "library": "@ark-ui/vue/toast",
      "primitive": "Toast.Root",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": [
        "data-scope",
        "data-part",
        "data-placement",
        "data-type",
        "aria-*",
        "data-*"
      ],
      "notes": "Toast 基于 Ark UI Toast.Root 封装，透传 ToastRootBaseProps；options 为 Rark 扩展配置。"
    },
    "capabilities": [
      "theme",
      "ui-override",
      "programmatic-api",
      "slots"
    ]
  },
  "contracts": {
    "props": [
      {
        "name": "options",
        "required": true,
        "requiredSource": "type",
        "typeText": "ToastOptions",
        "typeSchema": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["info", "success", "warning", "error", "loading"] },
            "placement": { "type": "string" },
            "title": {},
            "description": {},
            "render": { "type": "function" },
            "theme": { "type": "object" },
            "duration": { "type": "number" }
          },
          "required": []
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "单条提示配置（必填），含 type、title、description、render、theme、duration 等。"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | string[] | Record<string, boolean>",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } },
            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点附加 class。"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeNoCrafts['theme']",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "单条提示主题参数，与 options.theme 合并。"
      },
      {
        "name": "ui",
        "required": false,
        "requiredSource": "type",
        "typeText": "{ root?: class; content?: class; inner?: class; title?: class; description?: class; icon?: class; close?: class }",
        "typeSchema": {
          "type": "object",
          "properties": {
            "root": {},
            "content": {},
            "inner": {},
            "title": {},
            "description": {},
            "icon": {},
            "close": {}
          }
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "各结构节点 class 覆盖。"
      }
    ],
    "events": [],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": {
          "type": "object",
          "properties": {
            "options": {},
            "context": {}
          }
        },
        "renderWhen": [{ "expr": "!options?.render" }],
        "fallback": null,
        "description": "自定义整条提示结构；作用域含 options 与 context。"
      },
      {
        "name": "icon",
        "slotPropsSchema": {
          "type": "object",
          "properties": {
            "options": {},
            "context": {}
          }
        },
        "renderWhen": [{ "expr": "!options?.render" }],
        "fallback": "按 type 渲染默认图标",
        "description": "覆盖图标区域。"
      },
      {
        "name": "inner",
        "slotPropsSchema": {
          "type": "object",
          "properties": {
            "options": {},
            "context": {}
          }
        },
        "renderWhen": [{ "expr": "!options?.render" }],
        "fallback": "title + description",
        "description": "覆盖内容区域（标题与描述）。"
      },
      {
        "name": "close",
        "slotPropsSchema": {
          "type": "object",
          "properties": {
            "options": {},
            "context": {}
          }
        },
        "renderWhen": [{ "expr": "!options?.render && context.type !== 'loading'" }],
        "fallback": "ToastCloseTrigger",
        "description": "覆盖关闭区域；loading 类型默认不渲染关闭按钮。"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": { "enum": ["xs", "sm", "base", "lg"] },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "提示尺寸。"
        },
        {
          "name": "skin",
          "typeText": "'razer' | 'shadcn'",
          "typeSchema": { "enum": ["razer", "shadcn"] },
          "default": null,
          "defaultKind": "unknown",
          "description": "主题皮肤。"
        }
      ]
    },
    "uiConfiguration": {
      "fields": [
        {
          "name": "ui.root",
          "typeText": "string | array | object",
          "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "根节点 class 覆盖。"
        },
        {
          "name": "ui.content",
          "typeText": "string | array | object",
          "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "内容容器 class 覆盖。"
        },
        {
          "name": "ui.inner",
          "typeText": "string | array | object",
          "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "标题与描述容器 class 覆盖。"
        },
        {
          "name": "ui.title",
          "typeText": "string | array | object",
          "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "标题区域 class 覆盖。"
        },
        {
          "name": "ui.description",
          "typeText": "string | array | object",
          "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "描述区域 class 覆盖。"
        },
        {
          "name": "ui.icon",
          "typeText": "string | array | object",
          "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "图标区域 class 覆盖。"
        },
        {
          "name": "ui.close",
          "typeText": "string | array | object",
          "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "关闭按钮区域 class 覆盖。"
        }
      ]
    }
  },
  "behaviorModel": {
    "stateVars": {
      "type": "info | success | warning | error | loading",
      "placement": "string"
    },
    "derived": {
      "showCloseIcon": "type !== 'loading'",
      "iconVNode": "由 type 决定渲染的图标组件"
    },
    "transitions": [
      {
        "on": "options.render",
        "guard": "options?.render 存在",
        "effects": ["使用 render 完全接管渲染"]
      },
      {
        "on": "default",
        "guard": "无 options.render",
        "effects": ["渲染 icon + inner + close 插槽"]
      }
    ]
  },
  "examples": [
    {
      "id": "basic",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Toast" },
        "exampleId": "basic"
      },
      "description": "基础用法（类型与状态）"
    },
    {
      "id": "placements",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Toast" },
        "exampleId": "placements"
      },
      "description": "位置控制（多 Toaster）"
    },
    {
      "id": "duration-and-actions",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Toast" },
        "exampleId": "duration-and-actions"
      },
      "description": "持续时长、可关闭与操作按钮"
    },
    {
      "id": "promise",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Toast" },
        "exampleId": "promise"
      },
      "description": "Promise 生命周期提示"
    },
    {
      "id": "custom-render",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Toast" },
        "exampleId": "custom-render"
      },
      "description": "完全自定义渲染"
    },
    {
      "id": "slots-and-ui",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Toast" },
        "exampleId": "slots-and-ui"
      },
      "description": "插槽与 UI 覆盖"
    }
  ],
  "generationHints": {
    "preferredUsageOrder": [
      "useToast().toast.create/success/error/info/warning/loading",
      "ToasterManager + Toaster + Toast",
      "options.type + options.title + options.description"
    ],
    "safeDefaults": {
      "options": "必填"
    },
    "a11yChecklist": [
      "duration: Infinity 时应提供可见关闭入口",
      "关键流程建议使用 title + description 双层信息",
      "多位置容器并存时保持统一 placement 策略"
    ],
    "codegenTemplates": {
      "minimal": "toast.create({ title: '提示', type: 'info' })",
      "withDescription": "toast.success({ title: '成功', description: '操作已完成' })"
    },
    "antiPatterns": [
      "仅通过颜色表达状态，缺少 title/description 语义",
      "无 ToasterManager 时调用 useToast 会触发告警"
    ]
  },
  "provenance": {
    "sources": [
      { "path": "./toast.doc.mdx", "kind": "doc" },
      { "path": "./props.ts", "kind": "type" },
      { "path": "./Toast.vue", "kind": "runtime" },
      { "path": "./use-toast.ts", "kind": "runtime" },
      { "path": "./toast.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.props.options.required": "type",
      "contracts.slots.close.renderWhen": "runtime"
    }
  }
}
