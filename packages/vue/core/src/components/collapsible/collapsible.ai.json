  "generationHints": {
    "preferredUsageOrder": [
      "open/defaultOpen",
      "collapsedHeight",
      "indicator",
      "theme.size",
      "ui.*"
    ],
    "safeDefaults": {
      "defaultOpen": false,
      "disabled": false,
      "collapsedHeight": 0,
      "indicator": true
    },
    "a11yChecklist": [
      "Trigger 应提供可理解文本，不仅依赖图标。",
      "禁用态请使用 disabled 语义属性，不仅做样式灰化。",
      "自定义 indicator 插槽时保持状态可感知（展开/收起）。"
    ],
    "codegenTemplates": {
      "minimal": "<Collapsible><CollapsibleTrigger>Details</CollapsibleTrigger><CollapsibleContent>Content</CollapsibleContent></Collapsible>",
      "readMore": "<ReadMore :collapsed-height=\"60\">Long content...</ReadMore>"
    },
    "antiPatterns": [
      "在受控模式同时传 open 和 defaultOpen，导致状态来源冲突。",
      "ReadMore 内容很短仍强制渲染触发器，未利用高度测量逻辑。"
    ]
  },
