    "events": [
      {
        "name": "update:open",
        "payload": {
          "typeText": "boolean",
          "typeSchema": {
            "type": "boolean"
          }
        },
        "emitWhen": [
          {
            "expr": "open_state_changes",
            "kind": "runtime-machine"
          }
        ],
        "notEmitWhen": [
          {
            "expr": "disabled_prevents_toggle",
            "kind": "runtime-machine"
          }
        ],
        "order": [
          "internalStateUpdate",
          "emit:update:open"
        ],
        "description": "Collapsible/ReadMore 展开状态变化时用于 v-model:open 同步。"
      },
      {
        "name": "openChange",
        "payload": {
          "typeText": "{ open: boolean }",
          "typeSchema": {
            "type": "object",
            "properties": {
              "open": {
                "type": "boolean"
              }
            },
            "required": [
              "open"
            ],
            "additionalProperties": true
          }
        },
        "emitWhen": [
          {
            "expr": "open_state_changes",
            "kind": "runtime-machine"
          }
        ],
        "notEmitWhen": [],
        "order": [
          "internalStateUpdate",
          "emit:openChange"
        ],
        "description": "Ark UI 原生展开状态变化详情事件。"
      }
    ],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": {
          "type": "object",
          "properties": {
            "open": {
              "type": "boolean"
            },
            "visible": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "renderWhen": [
          {
            "expr": "always"
          }
        ],
        "fallback": null,
        "description": "Collapsible 根默认插槽（可访问 open/visible），以及 Trigger/Content/ReadMore 的主内容插槽。"
      },
      {
        "name": "indicator",
        "slotPropsSchema": {
          "type": "object",
          "properties": {
            "open": {
              "type": "boolean"
            },
            "visible": {
              "type": "boolean"
            }
          },
          "required": [
            "open",
            "visible"
          ],
          "additionalProperties": false
        },
        "renderWhen": [
          {
            "expr": "component === CollapsibleTrigger"
          }
        ],
        "fallback": "ChevronDown in Collapsible.Indicator when indicator=true",
        "description": "CollapsibleTrigger 自定义指示器插槽。"
      }
    ],
