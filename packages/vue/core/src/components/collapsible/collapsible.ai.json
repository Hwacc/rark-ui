{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.collapsible",
  "component": {
    "name": "Collapsible",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "Collapsible",
    "category": "core",
    "description": "用于在有限空间中切换内容的展开/收起状态组件组。基于 Ark UI collapsible 原语封装，包含 Collapsible、CollapsibleTrigger、CollapsibleContent 和 ReadMore，并扩展 theme 与部分 ui 配置能力。",
    "basePrimitive": {
      "library": "@ark-ui/vue/collapsible",
      "primitive": "Collapsible.RootProvider",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": [
        "id",
        "disabled",
        "aria-*",
        "data-*"
      ],
      "notes": "Collapsible 根组件透传 Ark UI Root 常用状态属性；Trigger/Content 透传 Ark 子原语属性。"
    },
    "capabilities": [
      "expand-collapse",
      "controlled",
      "uncontrolled",
      "read-more",
      "theme",
      "ui-override",
      "slot-composition"
    ]
  },
