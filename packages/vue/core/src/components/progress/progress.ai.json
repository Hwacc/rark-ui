{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.progress",
  "component": {
    "name": "Progress",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "Progress",
    "category": "core",
    "description": "用于展示任务完成度或流程进度，支持线性进度条、圆形进度和弧形进度三种形态。基于 Ark UI Progress 构建，保留 Ark UI 的进度状态与可访问性语义，扩展 theme、局部 ui 覆盖与 transfer 视觉变体能力。",
    "basePrimitive": {
      "library": "@ark-ui/vue/progress",
      "primitive": "Progress.RootProvider",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": ["aria-*", "data-*"],
      "notes": "根组件透传 Ark UI Root 常用能力（modelValue/defaultValue、min/max、orientation、formatOptions、translations 等），并扩展 theme 与根 class。"
    },
    "capabilities": [
      "modelValue",
      "min",
      "max",
      "orientation",
      "theme",
      "ui-override",
      "variant"
    ]
  },
  "contracts": {
    "props": [
      {
        "name": "modelValue",
        "required": false,
        "requiredSource": "type",
        "typeText": "number | null",
        "typeSchema": { "anyOf": [{ "type": "number" }, { "type": "null" }] },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": ["defaultValue"],
        "description": "受控进度值（配合 v-model）。"
      },
      {
        "name": "defaultValue",
        "required": false,
        "requiredSource": "type",
        "typeText": "number",
        "typeSchema": { "type": "number" },
        "default": 50,
        "defaultKind": "explicit-doc",
        "nullable": false,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": ["modelValue"],
        "description": "非受控初始值。"
      },
      {
        "name": "min",
        "required": false,
        "requiredSource": "type",
        "typeText": "number",
        "typeSchema": { "type": "number" },
        "default": 0,
        "defaultKind": "explicit-doc",
        "nullable": false,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "最小值。"
      },
      {
        "name": "max",
        "required": false,
        "requiredSource": "type",
        "typeText": "number",
        "typeSchema": { "type": "number" },
        "default": 100,
        "defaultKind": "explicit-doc",
        "nullable": false,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "最大值。"
      },
      {
        "name": "orientation",
        "required": false,
        "requiredSource": "type",
        "typeText": "'horizontal' | 'vertical'",
        "typeSchema": { "enum": ["horizontal", "vertical"] },
        "default": "horizontal",
        "defaultKind": "explicit-runtime",
        "nullable": false,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "进度方向（影响线性轨道布局）。"
      },
      {
        "name": "formatOptions",
        "required": false,
        "requiredSource": "type",
        "typeText": "NumberFormatOptions",
        "typeSchema": { "type": "object" },
        "default": { "style": "percent" },
        "defaultKind": "explicit-doc",
        "nullable": false,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "用于格式化值文本。"
      },
      {
        "name": "translations",
        "required": false,
        "requiredSource": "type",
        "typeText": "IntlTranslations",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "无障碍与值文本相关文案。"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvProgress'>",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "主题参数与 tvProgress crafts 覆盖。"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | array | object",
        "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点附加 class。"
      }
    ],
    "events": [
      {
        "name": "update:modelValue",
        "payload": {
          "typeText": "(value: number | null)",
          "typeSchema": { "type": "object", "properties": { "value": { "anyOf": [{ "type": "number" }, { "type": "null" }] } } }
        },
        "emitWhen": [{ "expr": "value_changed", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit_update_modelValue"],
        "description": "受控进度值同步。"
      },
      {
        "name": "valueChange",
        "payload": {
          "typeText": "(details: ValueChangeDetails)",
          "typeSchema": { "type": "object" }
        },
        "emitWhen": [{ "expr": "value_changed", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit_valueChange"],
        "description": "进度值变化时触发（Ark UI Root 事件）。"
      }
    ],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": { "type": "object", "properties": {}, "additionalProperties": false },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "主组合插槽，用于放置 ProgressLinear/ProgressCircle/ProgressArc 以及 Label/ValueText 等子节点。"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": { "enum": ["xs", "sm", "base", "lg"] },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "控制线性高度/圆形尺寸等视觉尺度。"
        },
        {
          "name": "orientation",
          "typeText": "'horizontal' | 'vertical'",
          "typeSchema": { "enum": ["horizontal", "vertical"] },
          "default": "horizontal",
          "defaultKind": "explicit-doc",
          "description": "参与 tvProgress 样式分支计算。"
        },
        {
          "name": "skin",
          "typeText": "'razer' | 'shadcn'",
          "typeSchema": { "enum": ["razer", "shadcn"] },
          "default": null,
          "defaultKind": "unknown",
          "description": "主题皮肤。"
        },
        {
          "name": "surface",
          "typeText": "'light' | 'dark'",
          "typeSchema": { "enum": ["light", "dark"] },
          "default": null,
          "defaultKind": "unknown",
          "description": "表面语义。"
        },
        {
          "name": "unstyled",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": null,
          "defaultKind": "unknown",
          "description": "是否移除内置样式。"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆写 tvProgress crafts 配置。"
        }
      ]
    },
    "uiConfiguration": {
      "fields": [
        {
          "name": "ProgressLinear.ui.track",
          "typeText": "string | array | object",
          "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "线性轨道 class 覆盖。"
        },
        {
          "name": "ProgressLinear.ui.range",
          "typeText": "string | array | object",
          "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "线性范围 class 覆盖。"
        },
        {
          "name": "ProgressCircle.ui.circle",
          "typeText": "string | array | object",
          "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "圆形根节点 class 覆盖。"
        },
        {
          "name": "ProgressCircle.ui.circleTrack",
          "typeText": "string | array | object",
          "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "圆形轨道 class 覆盖。"
        },
        {
          "name": "ProgressCircle.ui.circleRange",
          "typeText": "string | array | object",
          "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "圆形范围 class 覆盖。"
        }
      ]
    }
  },
  "behaviorModel": {
    "stateVars": {
      "value": "number | null",
      "min": "number",
      "max": "number",
      "orientation": "'horizontal' | 'vertical'"
    },
    "derived": {
      "percent": "value !== null ? (value - min) / (max - min) * 100 : 0"
    },
    "transitions": [
      {
        "on": "value_update",
        "guard": "always",
        "effects": ["updateValue", "emit_valueChange"]
      }
    ]
  },
  "examples": [
    {
      "id": "basic",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Progress" },
        "exampleId": "basic"
      },
      "description": "基础用法"
    },
    {
      "id": "linear-variants",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Progress" },
        "exampleId": "linear-variants"
      },
      "description": "线性变体（default/robbin/transfer）"
    },
    {
      "id": "sizes-and-orientation",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Progress" },
        "exampleId": "sizes-and-orientation"
      },
      "description": "尺寸与方向（横向/纵向）"
    },
    {
      "id": "circle-and-arc",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Progress" },
        "exampleId": "circle-and-arc"
      },
      "description": "圆形与弧形进度"
    },
    {
      "id": "custom-ui",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Progress" },
        "exampleId": "custom-ui"
      },
      "description": "UI 覆盖示例"
    }
  ],
  "generationHints": {
    "preferredUsageOrder": ["modelValue", "min", "max", "orientation", "theme"],
    "safeDefaults": {
      "defaultValue": 50,
      "min": 0,
      "max": 100,
      "orientation": "horizontal"
    },
    "a11yChecklist": [
      "组件基于 Ark UI，内置进度语义与可访问性。",
      "需要表达进度状态时使用 ProgressLabel、ProgressValueText。"
    ],
    "codegenTemplates": {
      "minimal": "<Progress :model-value=\"50\">\n  <ProgressLinear />\n</Progress>",
      "controlled": "<Progress v-model=\"value\">\n  <ProgressLinear variant=\"transfer\" />\n</Progress>"
    },
    "antiPatterns": [
      "同时混用受控和非受控。",
      "纵向进度未设置容器高度导致无法体现方向差异。"
    ]
  },
  "provenance": {
    "sources": [
      { "path": "./progress.doc.mdx", "kind": "doc" },
      { "path": "./props.ts", "kind": "type" },
      { "path": "./Progress.vue", "kind": "runtime" },
      { "path": "./progress.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.props.orientation.default": "runtime",
      "contracts.props.defaultValue.default": "doc",
      "contracts.props.min.default": "doc",
      "contracts.props.max.default": "doc"
    }
  }
}
