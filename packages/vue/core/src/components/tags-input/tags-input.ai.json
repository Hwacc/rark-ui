  "generationHints": {
    "preferredUsageOrder": ["modelValue", "inline", "max", "validate", "theme"],
    "safeDefaults": {
      "inline": true
    },
    "a11yChecklist": [
      "表单中提供明确的可见标签或辅助文案，不仅依赖 placeholder。",
      "invalid 状态建议同步外部错误提示文本。",
      "只读与禁用语义应区分：readOnly 保留可聚焦与可读，disabled 用于完全禁止交互。"
    ],
    "codegenTemplates": {
      "minimal": "<TagsInput v-model=\"tags\">\n  <template #default=\"{ items }\">\n    <TagsInputItem v-for=\"(item, i) in items\" :key=\"i\" :value=\"item\" :index=\"i\" />\n  </template>\n</TagsInput>",
      "withValidate": "<TagsInput v-model=\"tags\" :validate=\"(d) => !tags.includes(d.inputValue)\" />"
    },
    "antiPatterns": [
      "设置 max 时未同步监听 valueInvalid 给出失败原因。",
      "在多个事件里重复校验逻辑，未集中到 validate。"
    ]
  },
