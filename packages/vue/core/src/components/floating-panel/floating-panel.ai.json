{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.floating-panel",
  "component": {
    "name": "FloatingPanel",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "FloatingPanel",
    "category": "core",
    "description": "可拖拽、可缩放、可分阶段（最小化/最大化/默认）的浮动面板组件，适用于工具窗、悬浮配置面板、辅助调试面板等场景。基于 Ark UI Floating Panel 封装。",
    "basePrimitive": {
      "library": "@ark-ui/vue",
      "primitive": "ark.floating-panel",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": ["aria-*", "data-*"],
      "notes": "根组件透传 Ark UI Root 常用参数与状态机能力。"
    },
    "capabilities": [
      "theme",
      "draggable",
      "resizable",
      "stage",
      "opacity",
      "pinned"
    ]
  },
  "contracts": {
    "props": [
      {
        "name": "opacity",
        "required": false,
        "requiredSource": "type",
        "typeText": "number",
        "typeSchema": { "type": "number" },
        "default": 100,
        "defaultKind": "explicit-runtime",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "面板透明度（内部会被限制在 0-100）"
      },
      {
        "name": "pinned",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": false,
        "defaultKind": "explicit-runtime",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否固定面板；固定时会禁用拖拽"
      },
      {
        "name": "resizeAxis",
        "required": false,
        "requiredSource": "type",
        "typeText": "'x' | 'y' | 'xy' | 'xyc' | 'custom'",
        "typeSchema": { "enum": ["x", "y", "xy", "xyc", "custom"] },
        "default": "xyc",
        "defaultKind": "explicit-runtime",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "控制内置缩放触发器渲染策略"
      },
      {
        "name": "draggable",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": true,
        "defaultKind": "explicit-runtime",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否可拖拽（当 pinned=true 时会被强制关闭）"
      },
      {
        "name": "lazyMount",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否延迟挂载内容（Ark UI Root 参数）"
      },
      {
        "name": "unmountOnExit",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "关闭后是否卸载内容（Ark UI Root 参数）"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | array | object",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "array" },
            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点 class 覆盖"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvFloatingPanel'>",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "浮动面板主题变量与 crafts 覆盖入口"
      }
    ],
    "events": [
      {
        "name": "exitComplete",
        "payload": { "typeText": "() => void", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "exit_animation_complete", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:exitComplete"],
        "description": "退出动画结束时触发"
      },
      {
        "name": "openChange",
        "payload": { "typeText": "(details: OpenChangeDetails)", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "open_state_change", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:openChange"],
        "description": "打开状态变化时触发"
      },
      {
        "name": "update:open",
        "payload": { "typeText": "(open: boolean)", "typeSchema": { "type": "object", "properties": { "open": { "type": "boolean" } } } },
        "emitWhen": [{ "expr": "open_state_change", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:update:open"],
        "description": "用于双向绑定打开状态"
      },
      {
        "name": "positionChange",
        "payload": { "typeText": "(details: PositionChangeDetails)", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "position_realtime_change", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:positionChange"],
        "description": "位置实时变化时触发"
      },
      {
        "name": "update:position",
        "payload": { "typeText": "(position)", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "position_realtime_change", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:update:position"],
        "description": "用于双向绑定面板位置"
      },
      {
        "name": "positionChangeEnd",
        "payload": { "typeText": "(details: PositionChangeDetails)", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "drag_end", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:positionChangeEnd"],
        "description": "拖拽/位移结束时触发"
      },
      {
        "name": "sizeChange",
        "payload": { "typeText": "(details: SizeChangeDetails)", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "size_realtime_change", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:sizeChange"],
        "description": "尺寸实时变化时触发"
      },
      {
        "name": "update:size",
        "payload": { "typeText": "(size)", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "size_realtime_change", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:update:size"],
        "description": "用于双向绑定面板尺寸"
      },
      {
        "name": "sizeChangeEnd",
        "payload": { "typeText": "(details: SizeChangeDetails)", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "resize_end", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:sizeChangeEnd"],
        "description": "缩放结束时触发"
      },
      {
        "name": "stageChange",
        "payload": { "typeText": "(details: StageChangeDetails)", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "stage_change", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:stageChange"],
        "description": "阶段变化（最小化/最大化/默认）时触发"
      }
    ],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": { "type": "object", "properties": {}, "additionalProperties": false },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "放置触发器、内容与其它子组件"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": { "enum": ["xs", "sm", "base", "lg"] },
          "default": null,
          "defaultKind": "unknown",
          "description": "控制头部间距、触发器尺寸、缩放手柄尺寸"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆盖 positioner/content/header/control/title/trigger/resize* 槽位样式"
        }
      ]
    },
    "uiConfiguration": {
      "fields": []
    }
  },
  "behaviorModel": {
    "stateVars": {
      "opacity": "number",
      "pinned": "boolean",
      "draggable": "boolean"
    },
    "derived": {
      "effectiveDraggable": "!pinned && draggable",
      "opacityClamped": "clamp(opacity, 0, 100)"
    },
    "transitions": [
      {
        "on": "pin_toggle",
        "guard": "always",
        "effects": ["setPinned(!pinned)", "disableDraggableIfPinned"]
      },
      {
        "on": "opacity_change",
        "guard": "always",
        "effects": ["setOpacity(clamp(value, 0, 100))"]
      }
    ]
  },
  "examples": [
    { "id": "basic", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "FloatingPanel" }, "exampleId": "basic" }, "description": "基础组合" },
    { "id": "minimal", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "FloatingPanel" }, "exampleId": "minimal" }, "description": "最小可用结构" },
    { "id": "resize-axis", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "FloatingPanel" }, "exampleId": "resize-axis" }, "description": "缩放触发轴配置" },
    { "id": "min-size", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "FloatingPanel" }, "exampleId": "min-size" }, "description": "最小尺寸限制" },
    { "id": "initial-state", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "FloatingPanel" }, "exampleId": "initial-state" }, "description": "初始状态（透明度与固定）" }
  ],
  "generationHints": {
    "preferredUsageOrder": ["opacity", "pinned", "resizeAxis", "theme.size"],
    "safeDefaults": {
      "opacity": 100,
      "pinned": false,
      "resizeAxis": "xyc",
      "draggable": true
    },
    "a11yChecklist": [
      "推荐保持固定结构：FloatingPanel + FloatingPanelTrigger + FloatingPanelContent + FloatingPanelHeader",
      "将交互按钮统一放在 control 插槽中"
    ],
    "codegenTemplates": {
      "minimal": "<FloatingPanel><FloatingPanelTrigger><button>Open</button></FloatingPanelTrigger><FloatingPanelContent>...</FloatingPanelContent></FloatingPanel>",
      "withHeader": "<FloatingPanel><FloatingPanelTrigger>...</FloatingPanelTrigger><FloatingPanelContent><FloatingPanelHeader>Title</FloatingPanelHeader>...</FloatingPanelContent></FloatingPanel>"
    },
    "antiPatterns": [
      "手动改写拖拽逻辑实现固定能力，应使用 FloatingPanelPinTrigger",
      "外部多处状态源驱动透明度，应使用 setOpacity 统一更新"
    ]
  },
  "provenance": {
    "sources": [
      { "path": "./floating-panel.doc.mdx", "kind": "doc" },
      { "path": "./props.ts", "kind": "type" },
      { "path": "./FloatingPanel.vue", "kind": "runtime" },
      { "path": "./floating-panel.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.props.opacity.default": "runtime",
      "contracts.props.pinned.default": "runtime",
      "contracts.props.resizeAxis.default": "runtime",
      "contracts.props.draggable.default": "runtime"
    }
  }
}
