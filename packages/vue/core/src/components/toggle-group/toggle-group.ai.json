{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.toggle-group",
  "component": {
    "name": "ToggleGroup",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "ToggleGroup",
    "category": "core",
    "description": "用于管理一组可切换按钮，适合文本样式工具栏、视图模式切换、筛选条件等场景。基于 Ark UI Toggle Group 原语构建，支持单选/多选模式、受控/非受控值管理，并扩展 Rark UI 的 theme 样式能力。",
    "basePrimitive": {
      "library": "@ark-ui/vue/toggle-group",
      "primitive": "ToggleGroup.RootProvider",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": ["aria-*", "data-*"],
      "notes": "组件基于 Ark UI Toggle Group 封装，通过 useToggleGroup 管理组状态。"
    },
    "capabilities": [
      "v-model",
      "theme",
      "single-multiple",
      "orientation",
      "composite-item"
    ]
  },
  "contracts": {
    "props": [
      {
        "name": "modelValue",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | string[]",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "受控模式下的组值（配合 v-model）"
      },
      {
        "name": "defaultValue",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | string[]",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "非受控模式下的初始值"
      },
      {
        "name": "type",
        "required": false,
        "requiredSource": "doc",
        "typeText": "'single' | 'multiple'",
        "typeSchema": {
          "enum": ["single", "multiple"]
        },
        "default": "single",
        "defaultKind": "explicit-doc",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "选择模式：单选或多选"
      },
      {
        "name": "orientation",
        "required": false,
        "requiredSource": "doc",
        "typeText": "'horizontal' | 'vertical'",
        "typeSchema": {
          "enum": ["horizontal", "vertical"]
        },
        "default": "horizontal",
        "defaultKind": "explicit-runtime",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "布局方向"
      },
      {
        "name": "disabled",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "禁用整组交互"
      },
      {
        "name": "rovingFocus",
        "required": false,
        "requiredSource": "doc",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": true,
        "defaultKind": "explicit-doc",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否启用组内 roving focus 键盘导航"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | array | object",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "array" },
            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点附加 class"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvToggleGroup'>",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "主题参数与 crafts 覆写入口"
      }
    ],
    "events": [
      {
        "name": "update:modelValue",
        "payload": {
          "typeText": "(value: string | string[])",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        },
        "emitWhen": [
          { "expr": "value_changed", "kind": "runtime-hook" }
        ],
        "notEmitWhen": [],
        "order": ["emit:update:modelValue"],
        "description": "组值变化时触发，用于受控同步"
      },
      {
        "name": "valueChange",
        "payload": {
          "typeText": "Ark UI value change details",
          "typeSchema": { "type": "object" }
        },
        "emitWhen": [
          { "expr": "toggle_changed", "kind": "runtime-hook" }
        ],
        "notEmitWhen": [],
        "order": ["emit:valueChange"],
        "description": "底层 Ark UI 状态变化事件"
      }
    ],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "组内容器插槽，通常放置多个 ToggleGroupItem"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": {
            "enum": ["xs", "sm", "base", "lg"]
          },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "控制组项尺寸与间距密度"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "深度覆写 root/item 槽位样式"
        }
      ]
    },
    "uiConfiguration": {
      "fields": [
        {
          "name": "class",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "当前组件未提供 ui.* 分槽位配置，建议使用 class 覆盖"
        }
      ]
    }
  },
  "behaviorModel": {
    "stateVars": {
      "modelValue": "string | string[]",
      "type": "'single' | 'multiple'",
      "orientation": "'horizontal' | 'vertical'",
      "disabled": "boolean | undefined"
    },
    "derived": {
      "selectedItems": "type === 'single' ? [modelValue] : modelValue"
    },
    "transitions": [
      {
        "on": "item_toggle",
        "guard": "disabled !== true",
        "effects": [
          "update modelValue based on type",
          "emit(update:modelValue, value)",
          "emit(valueChange, details)"
        ]
      }
    ]
  },
  "examples": [
    {
      "id": "basic",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "ToggleGroup" },
        "exampleId": "basic"
      },
      "description": "基础用法"
    },
    {
      "id": "multiple",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "ToggleGroup" },
        "exampleId": "multiple"
      },
      "description": "多选模式（Multiple）"
    },
    {
      "id": "controlled",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "ToggleGroup" },
        "exampleId": "controlled"
      },
      "description": "单选模式与受控状态"
    },
    {
      "id": "orientation-and-disabled",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "ToggleGroup" },
        "exampleId": "orientation-and-disabled"
      },
      "description": "方向与禁用态"
    },
    {
      "id": "sizes",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "ToggleGroup" },
        "exampleId": "sizes"
      },
      "description": "尺寸变体"
    },
    {
      "id": "with-icons",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "ToggleGroup" },
        "exampleId": "with-icons"
      },
      "description": "图标项"
    }
  ],
  "generationHints": {
    "preferredUsageOrder": [
      "modelValue / defaultValue",
      "type",
      "orientation",
      "theme.size",
      "ToggleGroupItem.value"
    ],
    "safeDefaults": {
      "type": "single",
      "orientation": "horizontal",
      "rovingFocus": true
    },
    "a11yChecklist": [
      "图标项建议补充 aria-label",
      "禁用态使用 disabled 属性",
      "value 类型需一致"
    ],
    "codegenTemplates": {
      "minimal": "<ToggleGroup v-model=\"value\"><ToggleGroupItem value=\"a\">A</ToggleGroupItem><ToggleGroupItem value=\"b\">B</ToggleGroupItem></ToggleGroup>",
      "multiple": "<ToggleGroup v-model=\"values\" type=\"multiple\">...</ToggleGroup>"
    },
    "antiPatterns": [
      "互斥选择误用 type=\"multiple\"",
      "仅靠视觉样式模拟禁用",
      "同一组内 value 类型不一致"
    ]
  },
  "provenance": {
    "sources": [
      { "path": "./toggle-group.doc.mdx", "kind": "doc" },
      { "path": "./props.ts", "kind": "type" },
      { "path": "./ToggleGroup.vue", "kind": "runtime" },
      { "path": "./ToggleGroupItem.vue", "kind": "runtime" },
      { "path": "./toggle-group.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.props.orientation.default": "runtime",
      "contracts.props.type.default": "doc",
      "contracts.themeConfiguration.fields.size.default": "doc"
    }
  }
}
