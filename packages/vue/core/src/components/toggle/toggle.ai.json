{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.toggle",
  "component": {
    "name": "Toggle",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "Toggle",
    "category": "core",
    "description": "用于表达可按下/取消按下的二态按钮，适合静音、收藏、布局切换等即时状态开关场景。基于 Ark UI Toggle 构建，支持受控/非受控状态与表单语义透传，并扩展 theme 配置能力。",
    "basePrimitive": {
      "library": "@ark-ui/vue/toggle",
      "primitive": "Toggle.Root",
      "nativeElement": "button"
    },
    "passThrough": {
      "htmlAttributes": ["aria-pressed", "disabled", "id", "name", "value", "aria-*", "data-*"],
      "notes": "以 Ark UI Root 能力为主，透传 pressed/defaultPressed、disabled、asChild、id、name、value 等。"
    },
    "capabilities": [
      "pressed",
      "disabled",
      "asChild",
      "theme"
    ]
  },
  "contracts": {
    "props": [
      {
        "name": "pressed",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": ["defaultPressed"],
        "description": "受控按下状态（可配合 v-model:pressed）。"
      },
      {
        "name": "defaultPressed",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": ["pressed"],
        "description": "非受控模式下的初始按下状态。"
      },
      {
        "name": "disabled",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否禁用交互。"
      },
      {
        "name": "asChild",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": false,
        "defaultKind": "explicit-doc",
        "nullable": false,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "将交互能力合并到子元素。"
      },
      {
        "name": "id",
        "required": false,
        "requiredSource": "type",
        "typeText": "string",
        "typeSchema": { "type": "string" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "表单语义与标识。"
      },
      {
        "name": "name",
        "required": false,
        "requiredSource": "type",
        "typeText": "string",
        "typeSchema": { "type": "string" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "表单语义。"
      },
      {
        "name": "value",
        "required": false,
        "requiredSource": "type",
        "typeText": "string",
        "typeSchema": { "type": "string" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "表单值。"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "HTMLAttributes['class']",
        "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点附加 class。"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvToggle'>",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "主题参数与 crafts 覆写入口。"
      }
    ],
    "events": [
      {
        "name": "update:pressed",
        "payload": {
          "typeText": "(pressed: boolean)",
          "typeSchema": { "type": "object", "properties": { "pressed": { "type": "boolean" } } }
        },
        "emitWhen": [{ "expr": "pressed_state_changed", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit_update_pressed"],
        "description": "受控状态同步事件（用于 v-model:pressed）。"
      },
      {
        "name": "pressedChange",
        "payload": {
          "typeText": "(details: Ark UI pressed change details)",
          "typeSchema": { "type": "object" }
        },
        "emitWhen": [{ "expr": "pressed_state_changed", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit_pressedChange"],
        "description": "底层 Ark UI 状态变更事件，参数结构与 Ark UI 保持一致。"
      }
    ],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": { "type": "object", "properties": {}, "additionalProperties": false },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "按钮内容插槽，可放文本、图标或两者组合。"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": { "enum": ["xs", "sm", "base", "lg"] },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "控制按钮尺寸与内边距。"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆写 tvToggle crafts 生成逻辑。"
        }
      ]
    },
    "uiConfiguration": {
      "fields": []
    }
  },
  "behaviorModel": {
    "stateVars": {
      "pressed": "boolean",
      "disabled": "boolean"
    },
    "derived": {
      "isPressed": "pressed"
    },
    "transitions": [
      {
        "on": "click",
        "guard": "disabled !== true",
        "effects": ["togglePressed", "emit_pressedChange"]
      }
    ]
  },
  "examples": [
    {
      "id": "basic",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Toggle" },
        "exampleId": "basic"
      },
      "description": "基础用法（含图标）"
    },
    {
      "id": "states",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Toggle" },
        "exampleId": "states"
      },
      "description": "状态示例（默认/按下/禁用）"
    },
    {
      "id": "sizes",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Toggle" },
        "exampleId": "sizes"
      },
      "description": "尺寸变体"
    },
    {
      "id": "controlled",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Toggle" },
        "exampleId": "controlled"
      },
      "description": "受控模式"
    },
    {
      "id": "grouped",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Toggle" },
        "exampleId": "grouped"
      },
      "description": "分组使用（结合 ToggleGroup）"
    }
  ],
  "generationHints": {
    "preferredUsageOrder": ["pressed", "defaultPressed", "theme.size", "disabled"],
    "safeDefaults": {
      "asChild": false
    },
    "a11yChecklist": [
      "仅图标的 toggle 建议提供 aria-label 或可见文本。",
      "需要表达不可操作状态时使用 disabled，不要仅用视觉样式弱化。",
      "与表单联动时建议补齐 name 与 value。"
    ],
    "codegenTemplates": {
      "minimal": "<Toggle>Mute</Toggle>",
      "controlled": "<Toggle v-model:pressed=\"muted\">Mute</Toggle>"
    },
    "antiPatterns": [
      "仅靠 UI 禁用造成状态不一致，业务逻辑层未同时阻断动作。",
      "多个互斥或集合选择未交给 ToggleGroup 管理。"
    ]
  },
  "provenance": {
    "sources": [
      { "path": "./toggle.doc.mdx", "kind": "doc" },
      { "path": "./props.ts", "kind": "type" },
      { "path": "./Toggle.vue", "kind": "runtime" },
      { "path": "./toggle.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.props.asChild.default": "doc",
      "contracts.themeConfiguration.fields.size.default": "doc"
    }
  }
}
