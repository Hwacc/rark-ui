      },
      "description": "内容与 UI 自定义"
    }
  ],
  "generationHints": {
    "preferredUsageOrder": ["defaultOpen", "openDelay", "closeDelay", "positioning", "theme"],
    "safeDefaults": {
      "defaultOpen": false,
      "openDelay": 0,
      "closeDelay": 300
    },
    "a11yChecklist": [
      "优先使用 HoverCard + HoverCardTrigger asChild + HoverCardContent 的标准组合。",
      "内容区域建议保持短信息 + 轻操作，重交互场景改用 Dialog/Drawer。"
    ],
    "codegenTemplates": {
      "minimal": "<HoverCard>\n  <HoverCardTrigger asChild><Button>Hover</Button></HoverCardTrigger>\n  <HoverCardContent>Content</HoverCardContent>\n</HoverCard>",
      "controlled": "<HoverCard v-model:open=\"open\">...</HoverCard>"
    },
    "antiPatterns": [
      "悬停态承载复杂流程，应改用 Dialog/Drawer。",
      "密集列表中未调整 openDelay/closeDelay 导致误触和抖动。"
    ]
  },
  "provenance": {
    "sources": [
      { "path": "./hover-card.doc.mdx", "kind": "doc" },
      { "path": "./props.ts", "kind": "type" },
      { "path": "./HoverCard.vue", "kind": "runtime" },
      { "path": "./hover-card.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.props.defaultOpen.default": "doc",
      "contracts.props.openDelay.default": "doc",
      "contracts.props.closeDelay.default": "doc",
      "contracts.themeConfiguration.fields.size.default": "doc",
      "contracts.themeConfiguration.fields.bordered.default": "doc"
    }
  }
}
