{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.menu",
  "component": {
    "name": "Menu",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "Menu",
    "category": "core",
    "description": "复合菜单组件，用于承载命令选择、上下文菜单、单选/多选项等轻量操作入口。基于 Ark UI Menu 构建，支持受控与非受控状态、分组与子菜单。",
    "basePrimitive": {
      "library": "@ark-ui/vue/menu",
      "primitive": "ark.menu",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": ["aria-*", "data-*"],
      "notes": "Menu 根组件透传 MenuRootBaseProps，子组件在 Ark UI 原语之上补充 theme/ui 能力。"
    },
    "capabilities": [
      "theme",
      "ui-override",
      "checkbox-item",
      "radio-item",
      "submenu",
      "context-trigger"
    ]
  },
  "contracts": {
    "props": [
      {
        "name": "open",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "受控打开状态（可用 v-model:open）"
      },
      {
        "name": "defaultOpen",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "非受控初始打开状态"
      },
      {
        "name": "highlightedValue",
        "required": false,
        "requiredSource": "type",
        "typeText": "string",
        "typeSchema": { "type": "string" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "受控高亮项值（可用 v-model:highlighted-value）"
      },
      {
        "name": "lazyMount",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "延迟挂载内容"
      },
      {
        "name": "unmountOnExit",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "关闭后卸载内容"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | array | object",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "array" },
            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点附加 class"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvMenu' | 'tvCheckbox' | 'tvRadioGroup'>",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "菜单及关联选择器（checkbox/radio）的主题参数"
      }
    ],
    "events": [
      {
        "name": "select",
        "payload": { "typeText": "({ value: string; ... })", "typeSchema": { "type": "object", "properties": { "value": { "type": "string" } } } },
        "emitWhen": [{ "expr": "menu_item_selected", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:select"],
        "description": "菜单项被选择时触发"
      },
      {
        "name": "update:open",
        "payload": { "typeText": "(open: boolean)", "typeSchema": { "type": "object", "properties": { "open": { "type": "boolean" } } } },
        "emitWhen": [{ "expr": "open_state_change", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:update:open"],
        "description": "v-model:open 的更新事件"
      },
      {
        "name": "update:highlightedValue",
        "payload": { "typeText": "(value: string | undefined)", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "highlight_change", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:update:highlightedValue"],
        "description": "v-model:highlighted-value 的更新事件"
      }
    ],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": { "type": "object", "properties": {}, "additionalProperties": false },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "放置触发器与菜单内容结构"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": { "enum": ["xs", "sm", "base", "lg"] },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "控制菜单项字号、内边距与间距"
        },
        {
          "name": "bordered",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": true,
          "defaultKind": "explicit-doc",
          "description": "控制菜单内容区是否带边框"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆盖 tvMenu/tvCheckbox/tvRadioGroup crafts 配置"
        }
      ]
    },
    "uiConfiguration": {
      "fields": []
    }
  },
  "behaviorModel": {
    "stateVars": {
      "open": "boolean",
      "highlightedValue": "string | undefined"
    },
    "derived": {},
    "transitions": [
      {
        "on": "trigger_click",
        "guard": "open === false",
        "effects": ["setOpen(true)"]
      },
      {
        "on": "item_select",
        "guard": "always",
        "effects": ["emit(select)"]
      },
      {
        "on": "close_on_select",
        "guard": "closeOnSelect === true",
        "effects": ["setOpen(false)"]
      }
    ]
  },
  "examples": [
    { "id": "basic", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Menu" }, "exampleId": "basic" }, "description": "基础用法" },
    { "id": "submenu", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Menu" }, "exampleId": "submenu" }, "description": "子菜单" },
    { "id": "checkbox", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Menu" }, "exampleId": "checkbox" }, "description": "多选项（Checkbox）" },
    { "id": "radio", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Menu" }, "exampleId": "radio" }, "description": "单选项（Radio）" },
    { "id": "context-trigger", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Menu" }, "exampleId": "context-trigger" }, "description": "右键上下文菜单" },
    { "id": "controlled-open", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Menu" }, "exampleId": "controlled-open" }, "description": "受控打开与高亮项" },
    { "id": "sizes", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Menu" }, "exampleId": "sizes" }, "description": "尺寸主题" }
  ],
  "generationHints": {
    "preferredUsageOrder": ["open", "theme.size", "theme.bordered"],
    "safeDefaults": {
      "theme.bordered": true
    },
    "a11yChecklist": [
      "使用 Menu + MenuTrigger + MenuContent 作为固定骨架",
      "需要埋点时，优先监听根组件 select 事件",
      "多选与单选场景分别使用 MenuCheckboxItem 与 MenuRadioItemGroup"
    ],
    "codegenTemplates": {
      "minimal": "<Menu><MenuTrigger><button>Open</button></MenuTrigger><MenuContent><MenuItem value=\"item1\">Item 1</MenuItem></MenuContent></Menu>",
      "controlled": "<Menu v-model:open=\"open\">...</Menu>"
    },
    "antiPatterns": [
      "混用同一组选项状态模型于 checkbox 与 radio",
      "子菜单未独立 Menu 实例导致层级菜单遮挡"
    ]
  },
  "provenance": {
    "sources": [
      { "path": "./menu.doc.mdx", "kind": "doc" },
      { "path": "./props.ts", "kind": "type" },
      { "path": "./Menu.vue", "kind": "runtime" },
      { "path": "./menu.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.themeConfiguration.fields.size.default": "doc",
      "contracts.themeConfiguration.fields.bordered.default": "doc"
    }
  }
}
