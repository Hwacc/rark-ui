{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.switch",
  "component": {
    "name": "Switch",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "Switch",
    "category": "core",
    "description": "用于表达单一布尔开关状态（开/关），适合用于功能启停、偏好配置等场景。基于 Ark UI Switch 构建，支持受控/非受控状态、表单语义透传，并扩展 theme 与 ui 样式入口。",
    "basePrimitive": {
      "library": "@ark-ui/vue",
      "primitive": "ark.switch",
      "nativeElement": "button"
    },
    "passThrough": {
      "htmlAttributes": [
        "checked",
        "disabled",
        "readOnly",
        "required",
        "name",
        "value",
        "aria-*",
        "data-*"
      ],
      "notes": "组件基于 Ark UI Switch 原语封装，透传 checked/defaultChecked、disabled、readOnly、required、name、value 等。"
    },
    "capabilities": [
      "checked",
      "theme",
      "ui-override",
      "form-semantics"
    ]
  },
