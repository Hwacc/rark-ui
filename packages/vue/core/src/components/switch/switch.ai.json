    "events": [
      {
        "name": "update:checked",
        "payload": {
          "typeText": "(checked: boolean)",
          "typeSchema": { "type": "object", "properties": { "checked": { "type": "boolean" } } }
        },
        "emitWhen": [{ "expr": "checked_change_emit", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:update:checked"],
        "description": "受控状态同步事件（用于 v-model:checked）"
      },
      {
        "name": "checkedChange",
        "payload": {
          "typeText": "Ark UI checked change details",
          "typeSchema": { "type": "object" }
        },
        "emitWhen": [{ "expr": "ark_ui_checked_change", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:checkedChange"],
        "description": "底层 Ark UI 状态变化事件"
      }
    ],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": { "type": "object", "properties": {}, "additionalProperties": false },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "默认插槽；通常放置 SwitchLabel 或自定义描述内容"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": { "enum": ["xs", "sm", "base", "lg"] },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "控制开关轨道、滑块和标签字号"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆写 tvSwitch 的 crafts 配置"
        }
      ]
    },
    "uiConfiguration": {
      "fields": [
        { "name": "ui.root", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "根容器 class 覆盖" },
        { "name": "ui.control", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "控制区 class 覆盖" },
        { "name": "ui.thumb", "typeText": "string | array | object", "typeSchema": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }, "default": null, "defaultKind": "implicit-undefined", "description": "滑块 class 覆盖" }
      ]
    }
  },
  "behaviorModel": {
    "stateVars": {
      "checked": "boolean",
      "disabled": "boolean | undefined",
      "readOnly": "boolean | undefined"
    },
    "derived": {
      "isInteractive": "disabled !== true && readOnly !== true"
    },
    "transitions": [
      {
        "on": "click",
        "guard": "isInteractive",
        "effects": ["toggleChecked", "emit(update:checked)", "emit(checkedChange)"]
      }
    ]
  },
  "examples": [
    { "id": "basic", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Switch" }, "exampleId": "basic" }, "description": "基础用法" },
    { "id": "sizes", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Switch" }, "exampleId": "sizes" }, "description": "尺寸变体" },
    { "id": "states", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Switch" }, "exampleId": "states" }, "description": "状态示例" },
    { "id": "with-label", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Switch" }, "exampleId": "with-label" }, "description": "标签组合" },
    { "id": "controlled", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Switch" }, "exampleId": "controlled" }, "description": "受控模式" }
  ],
  "generationHints": {
    "preferredUsageOrder": ["checked", "defaultChecked", "theme.size", "disabled"],
    "safeDefaults": {
      "defaultChecked": false
    },
    "a11yChecklist": [
      "标签内容建议放在 SwitchLabel 中",
      "禁用与只读要区分：禁止交互用 disabled，仅阻止编辑用 readOnly",
      "表单使用时补齐 name、value、required"
    ],
    "codegenTemplates": {
      "minimal": "<Switch v-model:checked=\"enabled\" />",
      "withLabel": "<Switch v-model:checked=\"enabled\"><SwitchLabel>启用</SwitchLabel></Switch>"
    },
    "antiPatterns": [
      "把说明文本直接塞进 Switch 根节点造成结构不清晰",
      "仅通过 disabled 表达只读语义，应使用 readOnly 区分"
    ]
  },
