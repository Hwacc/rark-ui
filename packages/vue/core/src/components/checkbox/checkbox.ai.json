            { "type": "boolean" },
            { "const": "indeterminate" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "受控选中状态。"
      },
      {
        "name": "defaultChecked",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean | 'indeterminate'",
        "typeSchema": {
          "anyOf": [
            { "type": "boolean" },
            { "const": "indeterminate" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [
          "checked"
        ],
        "description": "非受控模式初始状态。"
      },
      {
        "name": "disabled",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": {
          "type": "boolean"
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否禁用交互。"
      },
      {
        "name": "readOnly",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": {
          "type": "boolean"
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "只读模式，不允许用户切换状态。"
      },
      {
        "name": "required",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": {
          "type": "boolean"
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "表单语义必填。"
      },
      {
        "name": "invalid",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": {
          "type": "boolean"
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否为错误状态。"
      },
      {
        "name": "name",
        "required": false,
        "requiredSource": "type",
        "typeText": "string",
        "typeSchema": {
          "type": "string"
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "表单字段名。"
      },
      {
        "name": "value",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | number | symbol | bigint | null",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "integer" },
            { "type": "null" }
          ],
          "x-ts-note": "symbol/bigint in TS"
        },
        "default": "on",
        "defaultKind": "explicit-doc",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "表单提交值或组内项值。"
      },
      {
        "name": "label",
        "required": false,
        "requiredSource": "type",
        "typeText": "string",
        "typeSchema": {
          "type": "string"
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "文本标签；可被 label 插槽覆盖。"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | array | object",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "array" },
            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点 class 覆盖。"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvCheckbox'>",
        "typeSchema": {
          "type": "object"
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "主题配置，驱动 tvCheckbox crafts。"
      },
      {
        "name": "ui",
        "required": false,
        "requiredSource": "type",
        "typeText": "{ root?: class; control?: class; indicator?: class; label?: class }",
        "typeSchema": {
          "type": "object",
          "properties": {
            "root": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
            "control": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
            "indicator": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
            "label": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }
          },
          "additionalProperties": false
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "分槽位 UI class 覆盖。"
      }
    ],
    "events": [
      {
        "name": "update:checked",
        "payload": {
          "typeText": "boolean | 'indeterminate'",
          "typeSchema": {
            "anyOf": [
              { "type": "boolean" },
              { "const": "indeterminate" }
            ]
          }
        },
        "emitWhen": [
          {
            "expr": "checked_state_changes",
            "kind": "runtime-machine"
          }
        ],
        "notEmitWhen": [
          {
            "expr": "disabled_or_readOnly_prevents_state_change",
            "kind": "runtime-machine"
          }
        ],
        "order": [
          "internalStateUpdate",
          "emit:update:checked"
        ],
        "description": "checked 状态变化时触发，用于 v-model:checked。"
      },
      {
        "name": "checkedChange",
        "payload": {
          "typeText": "Ark UI checked change details",
          "typeSchema": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "emitWhen": [
          {
            "expr": "checked_state_changes",
            "kind": "runtime-machine"
          }
        ],
        "notEmitWhen": [],
        "order": [
          "internalStateUpdate",
          "emit:checkedChange"
        ],
        "description": "Ark UI 原生状态变更事件。"
      }
    ],
    "slots": [
      {
        "name": "indicator",
        "slotPropsSchema": {
          "type": "object",
          "properties": {
            "checkedState": {
              "anyOf": [
                { "type": "boolean" },
                { "const": "indeterminate" }
              ]
            }
          },
          "required": [
            "checkedState"
          ],
          "additionalProperties": false
        },
        "renderWhen": [
          {
            "expr": "always"
          }
        ],
        "fallback": "Check / Minus icon",
        "description": "自定义指示器内容，接收 checkedState。"
      },
      {
        "name": "label",
        "slotPropsSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        },
        "renderWhen": [
          {
            "expr": "props.label || hasSlot('label')"
          }
        ],
        "fallback": "<span>{{ label }}</span>",
        "description": "自定义标签区域。"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": {
            "enum": ["xs", "sm", "base", "lg"]
          },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "复选框尺寸。"
        },
        {
          "name": "skin",
          "typeText": "'razer' | 'shadcn'",
          "typeSchema": {
            "enum": ["razer", "shadcn"]
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "主题皮肤。"
        },
        {
          "name": "surface",
          "typeText": "'light' | 'dark'",
          "typeSchema": {
            "enum": ["light", "dark"]
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "亮暗表面。"
        },
        {
          "name": "unstyled",
          "typeText": "boolean",
          "typeSchema": {
            "type": "boolean"
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "是否移除默认样式。"
        },
        {
          "name": "bordered",
          "typeText": "boolean",
          "typeSchema": {
            "type": "boolean"
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "是否显示边框。"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": {
            "type": "object"
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆盖 tvCheckbox crafts。"
        }
      ]
    },
    "uiConfiguration": {
      "fields": [
        {
          "name": "ui.root",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "根容器 class。"
        },
        {
          "name": "ui.control",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "控制框 class。"
        },
        {
          "name": "ui.indicator",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "指示器 class。"
        },
        {
          "name": "ui.label",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "标签 class。"
        }
      ]
    }
  },
  "behaviorModel": {
    "stateVars": {
      "checked": "boolean | 'indeterminate' | undefined",
      "disabled": "boolean | undefined",
      "readOnly": "boolean | undefined",
      "label": "string | undefined"
    },
    "derived": {
      "isInteractive": "disabled !== true && readOnly !== true",
      "showLabelNode": "Boolean(label) || hasSlot('label')",
      "showCheckIcon": "checked === true",
      "showIndeterminateIcon": "checked === 'indeterminate'"
    },
    "transitions": [
      {
        "on": "toggle-request",
        "guard": "isInteractive",
        "effects": [
          "computeNextCheckedState",
          "emit(update:checked, nextState)",
          "emit(checkedChange, details)"
        ]
      }
    ]
  },
