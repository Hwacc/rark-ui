    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.props.label": "type",
      "contracts.props.value.default": "doc",
      "contracts.events.update:checked.order": "runtime",
      "contracts.slots.label.renderWhen": "runtime",
      "contracts.themeConfiguration.fields.size.default": "doc"
    }
