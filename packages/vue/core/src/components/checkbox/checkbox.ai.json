{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.checkbox",
  "component": {
    "name": "Checkbox",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "Checkbox",
    "category": "core",
    "description": "用于布尔选择与多选集合项的复选框组件。基于 Ark UI checkbox 原语封装，支持 checked/indeterminate 状态、label 与 indicator 插槽，以及 theme/ui 样式扩展；可与 CheckboxGroup 组合管理值集合。",
    "basePrimitive": {
      "library": "@ark-ui/vue/checkbox",
      "primitive": "Checkbox.RootProvider",
      "nativeElement": "input[type=checkbox]"
    },
    "passThrough": {
      "htmlAttributes": [
        "id",
        "name",
        "required",
        "disabled",
        "readonly",
        "aria-*",
        "data-*"
      ],
      "notes": "核心交互与可访问性语义由 Ark UI checkbox machine 提供；Rark UI 增加 label、theme 与 ui 配置。"
    },
    "capabilities": [
      "checked",
      "indeterminate",
      "controlled",
      "uncontrolled",
      "theme",
      "ui-override",
      "form-participation",
      "group-selection"
    ]
  },
  "contracts": {
