  "generationHints": {
    "preferredUsageOrder": [
      "checked/defaultChecked",
      "label",
      "theme.size",
      "ui.*",
      "CheckboxGroup"
    ],
    "safeDefaults": {
      "defaultChecked": false,
      "disabled": false,
      "readOnly": false,
      "theme.size": "base"
    },
    "a11yChecklist": [
      "为每个 Checkbox 提供可见 label 或等效可访问名称。",
      "禁用态使用 disabled 语义，不仅是视觉灰化。",
      "中间态请使用 'indeterminate'，不要仅靠图标模拟。"
    ],
    "codegenTemplates": {
      "minimal": "<Checkbox label=\"Accept terms\" />",
      "group": "<CheckboxGroup v-model=\"values\"><Checkbox value=\"a\" label=\"A\" /><Checkbox value=\"b\" label=\"B\" /></CheckboxGroup>"
    },
    "antiPatterns": [
      "在受控模式同时传 checked 和 defaultChecked，导致状态来源混乱。",
      "仅用 class 模拟 disabled，而不设置 disabled/readOnly 语义。"
    ]
  },
  "provenance": {
    "sources": [
