        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Tabs" },
        "exampleId": "sizes"
      },
      "description": "尺寸变体"
    },
    {
      "id": "disabled-and-no-indicator",
      "mcp": {
        "server": "rark-ui",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Tabs" },
        "exampleId": "disabled-and-no-indicator"
      },
      "description": "禁用项与无指示器"
    }
  ],
  "generationHints": {
    "preferredUsageOrder": [
      "modelValue / defaultValue",
      "orientation",
      "theme.size",
      "TabsTrigger.value",
      "TabsContent.value"
    ],
    "safeDefaults": {
      "orientation": "horizontal",
      "TabsTrigger.disabled": false
    },
    "a11yChecklist": [
      "TabsTrigger.value 与 TabsContent.value 必须一一对应",
      "禁用项需提供可感知视觉反馈",
      "TabsIndicator 可选，但建议保留选中态反馈"
    ],
    "codegenTemplates": {
      "minimal": "<Tabs v-model=\"tab\"><TabsList><TabsTrigger value=\"a\">A</TabsTrigger><TabsTrigger value=\"b\">B</TabsTrigger></TabsList><TabsContent value=\"a\">内容 A</TabsContent><TabsContent value=\"b\">内容 B</TabsContent></Tabs>",
      "controlled": "<Tabs v-model=\"activeTab\" :orientation=\"'vertical'\">...</Tabs>"
    },
    "antiPatterns": [
      "TabsTrigger.value 与 TabsContent.value 不一致导致可点击无面板",
      "内容较重时未使用 lazyMount 与 unmountOnExit",
      "样式定制直接改内部结构而非 theme/class"
    ]
  },
  "provenance": {
    "sources": [
      { "path": "./tabs.doc.mdx", "kind": "doc" },
      { "path": "./props.ts", "kind": "type" },
      { "path": "./Tabs.vue", "kind": "runtime" },
      { "path": "./tabs.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.props.orientation.default": "runtime",
      "contracts.themeConfiguration.fields.size.default": "doc"
    }
  }
}
