{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.dialog",
  "component": {
    "name": "Dialog",
    "framework": "vue",
    "package": "@rark-ui/vue/core",
    "importPath": "@rark-ui/vue/core",
    "exportName": "Dialog",
    "category": "core",
    "description": "复合弹窗组件，用于承载确认、表单编辑、详情展示等临时交互内容。基于 Ark UI Dialog 构建，支持受控/非受控状态、关闭来源追踪（from）、主题配置。",
    "basePrimitive": {
      "library": "@ark-ui/vue/dialog",
      "primitive": "ark.dialog",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": ["aria-*", "data-*"],
      "notes": "DialogProps extends DialogRootBaseProps，属于部分透传 + 扩展模式。"
    },
    "capabilities": [
      "theme",
      "controlled-open",
      "from-tracking",
      "structured-content"
    ]
  },
  "contracts": {
    "props": [
      {
        "name": "open",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "受控打开状态（配合 v-model:open）"
      },
      {
        "name": "defaultOpen",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": false,
        "defaultKind": "explicit-doc",
        "nullable": false,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "非受控初始状态"
      },
      {
        "name": "lazyMount",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "延迟挂载内容"
      },
      {
        "name": "unmountOnExit",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "关闭后卸载内容"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | array | object",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "array" },
            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点自定义 class"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvDialog'>",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "Dialog 主题变量（尺寸、皮肤、crafts 等）"
      }
    ],
    "events": [
      {
        "name": "update:open",
        "payload": { "typeText": "(open: boolean)", "typeSchema": { "type": "object", "properties": { "open": { "type": "boolean" } } } },
        "emitWhen": [{ "expr": "open_state_change", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:update:open"],
        "description": "受控状态同步"
      },
      {
        "name": "openChange",
        "payload": { "typeText": "(details: { open: boolean; from: DialogTriggerFrom })", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "open_state_change", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:openChange"],
        "description": "打开状态变化（含触发来源）"
      },
      {
        "name": "escapeKeyDown",
        "payload": { "typeText": "(event: KeyboardEvent)", "typeSchema": { "type": "object", "x-ts-type": "KeyboardEvent" } },
        "emitWhen": [{ "expr": "escape_pressed", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:escapeKeyDown"],
        "description": "按下 ESC 触发"
      },
      {
        "name": "focusOutside",
        "payload": { "typeText": "(event: FocusOutsideEvent)", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "focus_outside", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:focusOutside"],
        "description": "焦点移出弹层时触发"
      },
      {
        "name": "interactOutside",
        "payload": { "typeText": "(event: InteractOutsideEvent)", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "interact_outside", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:interactOutside"],
        "description": "与弹层外部交互时触发"
      },
      {
        "name": "pointerDownOutside",
        "payload": { "typeText": "(event: PointerDownOutsideEvent)", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "pointer_down_outside", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:pointerDownOutside"],
        "description": "指针按下外部区域时触发"
      },
      {
        "name": "requestDismiss",
        "payload": { "typeText": "(event: RequestDismissEvent)", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "request_dismiss", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:requestDismiss"],
        "description": "请求关闭时触发"
      },
      {
        "name": "exitComplete",
        "payload": { "typeText": "()", "typeSchema": { "type": "object" } },
        "emitWhen": [{ "expr": "exit_animation_complete", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:exitComplete"],
        "description": "退出动画完成后触发"
      }
    ],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": { "type": "object", "properties": {}, "additionalProperties": false },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "放置触发器、内容等子组件"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": { "enum": ["xs", "sm", "base", "lg"] },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "控制弹窗尺寸相关样式"
        },
        {
          "name": "skin",
          "typeText": "'razer' | 'shadcn'",
          "typeSchema": { "enum": ["razer", "shadcn"] },
          "default": null,
          "defaultKind": "unknown",
          "description": "主题皮肤"
        },
        {
          "name": "surface",
          "typeText": "'light' | 'dark' | (string & {})",
          "typeSchema": { "type": "string" },
          "default": null,
          "defaultKind": "unknown",
          "description": "亮/暗表面语义"
        },
        {
          "name": "bordered",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": null,
          "defaultKind": "unknown",
          "description": "控制是否启用边框语义"
        },
        {
          "name": "unstyled",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": null,
          "defaultKind": "unknown",
          "description": "去除默认样式"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆盖 tvDialog 的 crafts 配置"
        }
      ]
    },
    "uiConfiguration": {
      "fields": []
    }
  },
  "behaviorModel": {
    "stateVars": {
      "open": "boolean"
    },
    "derived": {},
    "transitions": [
      {
        "on": "trigger_click",
        "guard": "open === false",
        "effects": ["setOpen(true)", "emit(openChange)"]
      },
      {
        "on": "close_trigger",
        "guard": "open === true",
        "effects": ["setOpen(false)", "emit(openChange)", "emit(exitComplete) on animation end"]
      }
    ]
  },
  "examples": [
    { "id": "basic", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Dialog" }, "exampleId": "basic" }, "description": "基础用法" },
    { "id": "controlled-and-events", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Dialog" }, "exampleId": "controlled-and-events" }, "description": "受控模式与事件" },
    { "id": "variants", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Dialog" }, "exampleId": "variants" }, "description": "尺寸与主题变体" },
    { "id": "scrollable", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Dialog" }, "exampleId": "scrollable" }, "description": "可滚动内容" },
    { "id": "content-close", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Dialog" }, "exampleId": "content-close" }, "description": "Content 关闭按钮控制" },
    { "id": "footer-widget", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Dialog" }, "exampleId": "footer-widget" }, "description": "Footer 按钮定制" },
    { "id": "functional", "mcp": { "server": "rark-ui", "tool": "get-example", "args": { "framework": "vue", "componentName": "Dialog" }, "exampleId": "functional" }, "description": "函数式调用" }
  ],
  "generationHints": {
    "preferredUsageOrder": ["open", "defaultOpen", "theme.size", "lazyMount"],
    "safeDefaults": {
      "defaultOpen": false
    },
    "a11yChecklist": [
      "优先使用 DialogHeader + DialogBody + DialogFooter 组合",
      "需要追踪关闭来源时，为触发器和关闭器配置 from",
      "内容较长时限制 DialogBody 高度并开启滚动"
    ],
    "codegenTemplates": {
      "minimal": "<Dialog><DialogTrigger><button>Open</button></DialogTrigger><DialogContent><DialogHeader>Title</DialogHeader><DialogBody>...</DialogBody></DialogContent></Dialog>",
      "controlled": "<Dialog v-model:open=\"open\">...</Dialog>"
    },
    "antiPatterns": [
      "自定义关闭区时未显式设置 show-close=\"false\"，导致重复关闭按钮",
      "复杂表单使用函数式 API 而非组件式组合"
    ]
  },
  "provenance": {
    "sources": [
      { "path": "./dialog.doc.mdx", "kind": "doc" },
      { "path": "./props.ts", "kind": "type" },
      { "path": "./Dialog.vue", "kind": "runtime" },
      { "path": "./dialog.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.props.defaultOpen.default": "doc",
      "contracts.themeConfiguration.fields.size.default": "doc"
    }
  }
}
