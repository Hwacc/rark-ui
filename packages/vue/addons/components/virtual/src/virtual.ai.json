          "typeSchema": {
            "type": "object",
            "properties": {
              "loading": { "type": "function" },
              "loaded": { "type": "function" },
              "complete": { "type": "function" },
              "error": { "type": "function" }
            }
          }
        },
        "emitWhen": [
          {
            "expr": "首次挂载且 enableFirstLoad 或 IntersectionObserver 命中",
            "kind": "runtime-hook"
          }
        ],
        "notEmitWhen": [],
        "order": ["loading", "loaded", "complete", "error"],
        "description": "首次加载或命中观察点时触发；业务侧通过回调切换加载状态。"
      }
    ],
